{
  "name": "repull-sdk-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Repull SDK monorepo — TypeScript SDK + interactive demo for api.repull.dev",
  "license": "SEE LICENSE.md",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @repull/demo build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm --filter @repull/demo dev",
    "dev:cm": "pnpm --filter @repull/channel-manager dev",
    "codegen": "tsx scripts/pull-openapi.ts && pnpm --filter @repull/types build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
