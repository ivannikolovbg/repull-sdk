# Optional: server-side sandbox key for "Use sandbox" button.
# When set, the client can hit POST /api/sandbox/use to switch the proxy
# to a Vanio-controlled demo key for browse-only flows.
REPULL_SANDBOX_API_KEY=

# Override the upstream API URL (defaults to https://api.repull.dev).
REPULL_API_BASE_URL=https://api.repull.dev
