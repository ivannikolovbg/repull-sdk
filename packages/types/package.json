{
  "name": "@repull/types",
  "version": "0.1.1",
  "description": "TypeScript types for the Repull API, generated from openapi.json.",
  "license": "SEE LICENSE.md",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "import": "./dist/openapi.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "openapi-typescript ../../openapi/v1.json -o src/openapi.ts && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  }
}
